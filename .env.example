# Required: API endpoint for transaction verification
VITE_API_ENDPOINT=https://your-api.example.com

# Required: WebSocket signaling server URL for WebRTC pairing
VITE_SIGNALING_URL=https://your-signaling-server.example.com

# Optional: TURN server for NAT traversal fallback
VITE_TURN_URL=turn:your-turn-server.example.com:3478
VITE_TURN_SECRET=your-turn-secret
